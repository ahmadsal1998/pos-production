# Server Configuration
PORT=5001
NODE_ENV=development

# MongoDB Configuration
# For Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/pos-system

# For MongoDB Atlas (Recommended for production):
# Replace YOUR_USERNAME, YOUR_PASSWORD, and cluster URL with your Atlas credentials
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/pos-system?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-this
JWT_REFRESH_EXPIRE=30d

# Frontend URL (for CORS). In production, only this and *.vercel.app origins are allowed.
CLIENT_URL=http://localhost:3000

# Log level: error | warn | info | debug. Production defaults to warn (per-request logs are debug-only).
# LOG_LEVEL=warn

# User Check Utility
CHECK_USER_EMAIL=your-email@example.com

# Products full sync cap (optional). Max products when all=true. Default 10000.
# MAX_PRODUCTS_FULL_SYNC=10000

# Admin login (env-based; do not commit real values)
# Use strong, unique values. Consider moving to DB admin user with hashed password and MFA later.
# ADMIN_USERNAME=your-admin-username
# ADMIN_PASSWORD=your-strong-password-min-12-chars
